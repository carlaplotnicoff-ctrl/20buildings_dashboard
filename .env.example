# SPIRE — Required Environment Variables
# Copy this to .env and fill in your values.
# .env is gitignored — never commit the real .env file.

# Supabase — get from https://app.supabase.com/project/gapfldixgqpmlzwijftm/settings/api
VITE_SUPABASE_URL=https://gapfldixgqpmlzwijftm.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# HubSpot — private app token (used for manual sync script)
VITE_HUBSPOT_TOKEN=your_hubspot_private_app_token_here

# Supabase CLI — required to deploy Edge Functions
# Get from https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# The following secrets are set DIRECTLY in Supabase Edge Function secrets
# (not in .env) — do NOT add them here:
#   ANTHROPIC_API_KEY     → set via Supabase dashboard > Edge Functions > Secrets
#   SUPABASE_SERVICE_ROLE_KEY → auto-injected by Supabase runtime
#   HUBSPOT_TOKEN         → set via Supabase dashboard if used in Edge Functions
